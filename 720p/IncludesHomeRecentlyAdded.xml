<includes>

    <include name="WidgetLocation">
        <left>5</left>
        <top>100</top>    
    </include>

    <include name="ActiveLabel">
        <control type="label">  
            <left>20</left>
            <top>0</top>
            <height>20</height>
            <width>540</width>
            <label>Active</label>
            <font>font30_title</font>
            <textcolor>white</textcolor>
            <shadowcolor>black</shadowcolor>
            <!--<angle>-90</angle>-->
        </control>  
    </include>
    
    <include name="RecentLabel">
        <control type="label">
            <left>20</left>
