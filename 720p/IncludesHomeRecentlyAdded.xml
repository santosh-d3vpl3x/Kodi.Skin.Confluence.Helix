    <include name="WidgetItems">
        <onleft>-</onleft>
        <onright>-</onright>
        <left>0</left>
        <top>40</top>
        <width>1280</width>
        <height>220</height>
        <viewtype label="535">list</viewtype>
        <pagecontrol>-</pagecontrol>
        <scrolltime>200</scrolltime>
        <orientation>Horizontal</orientation>    
        <itemlayout height="148" width="256">
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>246</width>
                <height>138</height>
                <texture background="true">$INFO[ListItem.Icon]</texture>
                <bordertexture border="5">button-nofocus.png</bordertexture>
                <bordersize>5</bordersize>
                <aspectratio>scale</aspectratio>
            </control>

            <!-- Progress Bar -->
            <control type="image">
                <left>5</left>
                <top>104</top>
                <width>236</width>
                <height>5</height>
                <texture background="true">Progress\progress_$INFO[ListItem.Property(complete_percentage)].png</texture>
                <colordiffuse>66FFFFFF</colordiffuse>
                <aspectratio>stretch</aspectratio>
                <visible>!IsEmpty(ListItem.Property(complete_percentage))</visible>
            </control>            

            <!-- top label -->
            <control type="image">
                <left>5</left>
                <top>5</top>
                <width>236</width>
                <height>24</height>
                <aspectratio>stretch</aspectratio>
                <texture>black-back.png</texture>
                <visible>!IsEmpty(ListItem.Label2)</visible>
                <colordiffuse>88FFFFFF</colordiffuse>
            </control>            
            <control type="label">
                <left>10</left>
